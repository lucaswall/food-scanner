# Database (local Docker Postgres — matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/food_scanner

# Session (iron-session password, min 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# App URL
APP_URL=http://localhost:3000

# Auth
ALLOWED_EMAILS=wall.lucas@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Google Health dry-run mode — REQUIRED on staging and production (boot guard enforced)
# When true, Health API write calls are no-ops (safe for staging/testing).
# Staging  (food-test.lucaswall.me): MUST be "true"   — boot fails if missing or wrong
# Production (food.lucaswall.me):    MUST be "true" or "false" explicitly — boot fails if unset
# Local dev (localhost):             Optional — any recognized value or omit
# Only "true" and "false" are accepted; typos like "TRUE" or "1" abort the boot.
# Google Health API scopes are configured on the GCP consent screen, not via env vars.
HEALTH_DRY_RUN=true

# E2E Testing (set to "true" to enable test-only auth bypass route)
# ENABLE_TEST_AUTH=true

# Logging (optional, defaults to debug in development)
# LOG_LEVEL=debug

# Sentry (optional — monitoring disabled when DSN is not set)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=       # Required at build time for source map uploads
# SENTRY_ORG=lucas-wall
# SENTRY_PROJECT=food-scanner
